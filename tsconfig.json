{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src/backend",
    "declaration": true
  },
  "include": ["src/backend/**/*"],
  "exclude": ["node_modules", "dist"]
}